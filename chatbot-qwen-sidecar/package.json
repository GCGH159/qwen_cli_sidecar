{
  "name": "chatbot-qwen-sidecar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pm2:start": "pnpm run build && pm2 start ecosystem.config.cjs --only claude-sidecar",
    "pm2:restart": "pnpm run build && pm2 restart claude-sidecar --update-env",
    "pm2:stop": "pm2 stop claude-sidecar",
    "pm2:delete": "pm2 delete claude-sidecar",
    "pm2:logs": "pm2 logs claude-sidecar"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@qwen-code/sdk": "^0.1.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.6.1",
    "pm2": "^6.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
